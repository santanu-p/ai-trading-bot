# ╔════════════════════════════════════════════════════════════╗
# ║              AI Trading Bot — Environment Config          ║
# ╠════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and fill in your values.          ║
# ║  Lines starting with # are comments.                      ║
# ║  Empty values = disabled / use defaults.                  ║
# ╚════════════════════════════════════════════════════════════╝

# ── Infrastructure ────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tradingbot
REDIS_URL=redis://localhost:6379/0
ENVIRONMENT=development
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ── Authentication & Security ─────────────────────────────────
# Generate a strong random string (≥ 32 chars for staging/production)
# Linux/Mac:   openssl rand -hex 32
# PowerShell:  [System.Guid]::NewGuid().ToString("N") + [System.Guid]::NewGuid().ToString("N")
SESSION_SECRET=change-me
SESSION_EXPIRE_MINUTES=720
SESSION_COOKIE_NAME=tradingbot_session
CSRF_COOKIE_NAME=tradingbot_csrf
CSRF_HEADER_NAME=x-csrf-token
SESSION_COOKIE_SECURE=false
CSRF_ORIGIN_ENFORCEMENT=true

# ── Operator Accounts ─────────────────────────────────────────
# Admin account (required)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=

# Optional additional operator accounts
OPERATOR_EMAIL=
OPERATOR_PASSWORD=
OPERATOR_PASSWORD_HASH=
REVIEWER_EMAIL=
REVIEWER_PASSWORD=
REVIEWER_PASSWORD_HASH=

# Legacy fallback names (still honored by config.py)
JWT_SECRET=
JWT_EXPIRE_MINUTES=720

# ── LLM Provider (at least one required) ──────────────────────
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash

# ── Alpaca Broker ─────────────────────────────────────────────
# Legacy fallback (used if paper/live-specific keys are not set)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Paper trading credentials (required)
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=

# Live trading credentials (only if ALLOW_LIVE_TRADING=true)
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=

# Alpaca API endpoints
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets
ALPACA_LIVE_BASE_URL=https://api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_MARKET_DATA_FEED=iex

# ── Trading Configuration ─────────────────────────────────────
MARKET_TIMEZONE=America/New_York
SCAN_INTERVAL_MINUTES=5
CONSENSUS_THRESHOLD=0.64
MIN_APPROVAL_VOTES=2
ALLOW_LIVE_TRADING=false
LIVE_TRADING_ALLOWED_BROKERS=alpaca
LIVE_ENABLE_CODE_TTL_MINUTES=10
INTRADAY_FLATTEN_BUFFER_MINUTES=15

# ── Rate Limiting & Security ──────────────────────────────────
REQUEST_BODY_MAX_BYTES=1000000
API_RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_WINDOW_SECONDS=60

# ── Stream Supervisor ─────────────────────────────────────────
STREAM_POLL_INTERVAL_SECONDS=5

# ── Alert Routing ─────────────────────────────────────────────
# Comma-separated webhook URLs for alert delivery
ALERT_WEBHOOK_URLS=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5

# Slack incoming webhook (optional — receives warning+ severity alerts)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# PagerDuty Events API v2 (optional — receives critical+ severity alerts)
# PAGERDUTY_WEBHOOK_URL=https://events.pagerduty.com/v2/enqueue

# Opsgenie webhook (optional — receives critical+ severity alerts)
# OPSGENIE_WEBHOOK_URL=https://api.opsgenie.com/v2/alerts

# ── ML Model Storage ──────────────────────────────────────────
# Directory for persisting trained ML signal models
# ML_MODEL_DIR=data/models
